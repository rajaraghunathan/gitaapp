    "2_1_ta": {
        "description": "சஞ்சயன் சொன்னான்: இவ்வாறு பரிதாபப்பட்டவனும், கண்களில் கண்ணீரால் நிரம்பியவனும், மனச்சோர்வும், திகைப்பும் கொண்டவனிடம், ஸ்ரீ கிருஷ்ணர் இவ்வாறு கூறினார்:",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "तम्",
                "en": "அவருக்கு"
            },
            {
                "sa": "तथा",
                "en": "இதனால்"
            },
            {
                "sa": "कृपया",
                "en": "பரிதாபத்துடன்"
            },
            {
                "sa": "आविष्टम्",
                "en": "கடக்க"
            },
            {
                "sa": "अश्रुपूर्णाकुलेक्षणम्",
                "en": "கண்கள் கண்ணீர் நிறைந்து கலவரத்துடன்"
            },
            {
                "sa": "विषीदन्तम्",
                "en": "நம்பிக்கையிழந்தவர்"
            },
            {
                "sa": "इदम्",
                "en": "இது"
            },
            {
                "sa": "वाक्यम्",
                "en": "பேச்சு"
            },
            {
                "sa": "उवाच",
                "en": "பேசினார்"
            },
            {
                "sa": "मघुसूदनः",
                "en": "மதுசூதனன்"
            }
        ]
    },
    "1_1_hi": {
        "description": "धृतराष्ट्र ने कहा: हे संजय, मेरी प्रजा और पांडवों ने क्या किया, जो युद्ध के लिए उत्सुक होकर, कुरूक्षेत्र के पवित्र मैदान में एकत्र हुए थे?",
        "footnotes": {
            "3": "संजय गवलगामा नामक सारथी का पुत्र था, वह शास्त्रों का एक अत्यंत विद्वान विद्वान, उदार और निष्पक्ष और सच्चा होने के कारण धर्म का कट्टर अभ्यासी था। इन्हीं कारणों से भीष्म ने उन्हें विदुर के साथ राजा धृतराष्ट्र का दूसरा मंत्री नियुक्त किया।"
        },
        "anvayam": [
            {
                "sa": "धर्मक्षेत्रे",
                "en": "पवित्र मैदान पर"
            },
            {
                "sa": "कुरुक्षेत्रे",
                "en": "कुरूक्षेत्र में"
            },
            {
                "sa": "समवेताः",
                "en": "एक साथ इकट्ठे हुए"
            },
            {
                "sa": "युयुत्सवः",
                "en": "लड़ने को इच्छुक"
            },
            {
                "sa": "मामकाः",
                "en": "मेरे लोग"
            },
            {
                "sa": "पाण्डवाः",
                "en": "पांडु के पुत्र"
            },
            {
                "sa": "च",
                "en": "और"
            },
            {
                "sa": "एव",
                "en": "भी"
            },
            {
                "sa": "किम्",
                "en": "क्या"
            },
            {
                "sa": "अकुर्वत",
                "en": "किया करुंगा"
            },
            {
                "sa": "सञ्जय",
                "en": "हे संजय!"
            }
        ]
    },
    "1_1_te": {
        "description": "ధృతరాష్ట్రుడు ఇలా అన్నాడు: ఓ సంజయా(3), కురుక్షేత్ర పుణ్యక్షేత్రంలో యుద్ధానికి ఆసక్తితో సమావేశమైన నా ప్రజలు మరియు పాండవులు ఏమి చేసారు?",
        "footnotes": {
            "3": "సంజయుడు గావల్గామ అనే రథసారథి కుమారుడు, అతను గ్రంధాలలో చాలా నేర్చుకున్న పండితుడు, ఉదారత మరియు నిష్పక్షపాతంగా మరియు సత్యంగా ధర్మాన్ని అనుసరించే స్థిరమైన అభ్యాసకుడు. ఈ కారణాల వల్ల భీష్ముడు విదురుని రాజు ధృతరాష్ట్ర రెండవ మంత్రిగా మొదటి మంత్రిగా నియమించాడు."
        },
        "anvayam": [
