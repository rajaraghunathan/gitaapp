    "3_1_te": {
        "description": "అర్జునుడు ఇలా అన్నాడు: ఓ కృష్ణా, కర్మ (క్రియ) కంటే బుద్ధి (బుద్ధి-వికాసం) గొప్పదని మీరు భావిస్తే, ఈ భయంకరమైన పనిలో నిమగ్నమవ్వమని నన్ను ఎందుకు ప్రేరేపిస్తావు?",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "ज्यायसी",
                "en": "ఉన్నతమైన"
            },
            {
                "sa": "चेत्",
                "en": "ఉంటే"
            },
            {
                "sa": "कर्मणः",
                "en": "చర్య కంటే"
            },
            {
                "sa": "ते",
                "en": "నీ ద్వారా"
            },
            {
                "sa": "मता",
                "en": "అనుకున్నాడు"
            },
            {
                "sa": "बुद्धिः",
                "en": "జ్ఞానం"
            },
            {
                "sa": "जनार्दन",
                "en": "ఓ జనార్దన"
            },
            {
                "sa": "तत्",
                "en": "అప్పుడు"
            },
            {
                "sa": "किम्",
                "en": "ఎందుకు"
            },
            {
                "sa": "कर्मणि",
                "en": "చర్యలో"
            },
            {
                "sa": "घोरे",
                "en": "భయంకరమైన"
            },
            {
                "sa": "माम्",
                "en": "నన్ను"
            },
            {
                "sa": "नियोजयसि",
                "en": "నీవు నిశ్చితార్థం చేసుకో"
            },
            {
                "sa": "केशव",
                "en": "ఓ కేశవా"
            }
        ]
