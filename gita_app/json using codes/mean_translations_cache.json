    "14_7_ta": {
        "description": "ஓ அர்ஜுனா (குந்தியின் மகனே) தெரிந்துகொள்ளுங்கள், ரஜஸ் என்பது நாட்டம் மற்றும் பற்றுதலால் எழும் மோகத்தின் இயல்பு, அது செயலின் மீதான பற்றுதலின் மூலம் உருவான சுயத்தின் பந்தத்தை ஏற்படுத்துகிறது. 165",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "रजः",
                "en": "ராஜஸ்"
            },
            {
                "sa": "रागात्मकम्",
                "en": "பேரார்வத்தின் தன்மை"
            },
            {
                "sa": "विद्धि",
                "en": "தெரியும்"
            },
            {
                "sa": "तृष्णासङ्गसमुद्भवम्",
                "en": "தாகம் மற்றும் பற்றுதலின் ஆதாரம்"
            },
            {
                "sa": "तत्",
                "en": "என்று"
            },
            {
                "sa": "निबध्नाति",
                "en": "பிணைக்கிறது"
            },
            {
                "sa": "कौन्तेय",
                "en": "குந்தியின் மகனே (அர்ஜுனன்)"
            },
            {
                "sa": "कर्मसङ्गेन",
                "en": "செயலின் மீதான பற்றுதலால்"
            },
            {
                "sa": "देहिनम्",
                "en": "பொதிந்த ஒன்று"
            }
        ]
    },
    "18_1_ta": {
        "description": "அர்ஜுனன் சொன்னான்: ஓ கிருஷ்ணா துறப்பதற்கும் (சன்னியாசம்) துறப்பதற்கும் (தியாகம்) உள்ள வித்தியாசத்தைப் பற்றிய தீர்க்கமான உண்மையை அறிய விரும்புகிறேன்.",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "संन्यासस्य",
                "en": "துறத்தல்"
            },
            {
                "sa": "महाबाहो",
                "en": "ஓ வலிமைமிக்கவன்"
            },
            {
                "sa": "तत्त्वम्",
                "en": "உண்மையின் சாராம்சம்"
            },
            {
                "sa": "इच्छामि",
                "en": "(நான்) விரும்புகிறேன்"
            },
            {
                "sa": "वेदितुम्",
                "en": "தெரிந்து கொள்ள"
            },
            {
                "sa": "त्यागस्य",
                "en": "தியாகம் அல்லது கைவிடுதல்"
            },
            {
                "sa": "च",
                "en": "மற்றும்"
            },
            {
                "sa": "हृषीकेशः",
                "en": "ஓ கிருஷ்ணா"
            },
            {
                "sa": "पृथक्",
                "en": "பலவிதமாக"
            },
            {
                "sa": "केशिनिषूदन्",
                "en": "கேசியைக் கொன்றவன்"
            }
        ]
    },
    "1_4_ta": {
        "description": "அங்கே (அந்தப் படையில்) பீமன், அர்ஜுனன் போன்ற பெரிய வில்லாளிகள்; யுயுதனன், விராடன் மற்றும் துருபதன் ஒரு வலிமைமிக்க போர்வீரன்.",
        "footnotes": {
            "7": "யுயோதனன் என்பது கிருஷ்ணரின் நெருங்கிய மற்றும் பிரியமான ஊழியரான சாத்யகியின் மற்றொரு பெயர்.",
            "8": "விராடன் மத்ஸ்ய மன்னன், அவனது பாதுகாப்பில் பாண்டவர்கள் மறைந்திருந்து தங்கள் கடைசி ஆண்டு வனவாசத்தை கழித்தனர். அவரது மகள் உத்தரா பின்னர் அர்ஜுனனின் மகன் அபிமன்யுவை மணந்தார். விராடன் தனது மகன்களான உத்தரா, ஷ்வேதா மற்றும் சங்கா ஆகியோருடன் போரில் கொல்லப்பட்டார்.",
            "9": "மஹா-ரதா - \"பெரிய தேர் வீரர்\" - ஒரே நேரத்தில் 1000 வில்லாளர்களுடன் சண்டையிடும் திறன் கொண்ட மிகவும் திறமையான தற்காப்புக் கலைஞர்."
        },
        "anvayam": [
            {
                "sa": "अत्र",
                "en": "இங்கே"
            },
            {
                "sa": "शूराः",
                "en": "ஹீரோக்கள்"
            },
            {
                "sa": "महेष्वासाः",
                "en": "வலிமைமிக்க வில்லாளர்கள்"
            },
            {
                "sa": "भीमार्जुनसमाः",
                "en": "பீமனுக்கும் அர்ஜுனனுக்கும் வணக்கம்"
            },
            {
                "sa": "युधि",
                "en": "போரில்"
            },
            {
                "sa": "युयुधानः",
                "en": "யுயுதானா"
            },
            {
                "sa": "विराटः",
                "en": "விராடா"
            },
            {
                "sa": "च",
                "en": "மற்றும்"
            },
            {
                "sa": "द्रुपदः",
                "en": "துருபதா"
            },
            {
                "sa": "च",
                "en": "மற்றும்"
            },
            {
                "sa": "महारथः",
                "en": "பெரிய காரின்"
            }
        ]
    },
    "1_41_ta": {
        "description": "அநியாயம் மேலோங்கும் போது, ​​ஓ கிருஷ்ணா, குலப் பெண்கள் கெட்டுப்போகின்றனர்; பெண்கள் ஊழல் செய்யும் போது, ​​வகுப்புகளின் கலப்பு ஏற்படுகிறது.",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "अधर्माभिभवात्",
                "en": "துரோகத்தின் பரவலில் இருந்து"
            },
            {
                "sa": "कृष्ण",
                "en": "ஓ கிருஷ்ணா"
            },
            {
                "sa": "प्रदुष्यन्ति",
                "en": "ஊழல் ஆகிவிடும்"
            },
            {
                "sa": "कुलस्त्रियः",
                "en": "குடும்பத்தின் பெண்கள்"
            },
            {
                "sa": "स्त्रीषु",
                "en": "பெண்களில்"
            },
            {
                "sa": "दुष्टासु",
                "en": "(இருத்தல்) ஊழல்"
            },
            {
                "sa": "वार्ष्णेय",
                "en": "ஓ வர்ஷ்ணேயா"
            },
            {
                "sa": "जायते",
                "en": "எழுகிறது"
            },
            {
                "sa": "वर्णसङ्करः",
                "en": "சாதிக்கலவை"
            }
        ]
    },
    "9_1_ta": {
        "description": "ஆசீர்வதிக்கப்பட்ட இறைவன் கூறினார்: இந்த மிகவும் இரகசியமான அறிவை, அதன் நடைமுறைப் பயன்பாடுகளுடன் சேர்த்து, உங்களுக்கு உதவாதவற்றிலிருந்து நீங்கள் விடுவிக்கப்படுவீர்கள் என்பதை அறியாத உங்களுக்கு நான் அறிவிக்கிறேன்.",
        "footnotes": {},
        "anvayam": [
            {
                "sa": "इदम्",
                "en": "இது"
            },
            {
                "sa": "तु",
                "en": "உண்மையில்"
            },
            {
                "sa": "ते",
                "en": "உனக்கு"
            },
            {
                "sa": "गुह्यतमम्",
                "en": "மிகப்பெரிய ரகசியம்"
            },
            {
                "sa": "प्रवक्ष्यामि",
                "en": "(I) அறிவிக்கிறேன்"
            },
            {
                "sa": "अनसूयवे",
                "en": "கேவல் செய்யாதவனுக்கு"
            },
            {
                "sa": "ज्ञानम्",
                "en": "அறிவு"
            },
            {
                "sa": "विज्ञानसहितम्",
                "en": "அனுபவத்துடன் இணைந்தது"
            },
            {
                "sa": "यत्",
                "en": "எது"
            },
            {
                "sa": "ज्ञात्वा",
                "en": "தெரிந்து கொண்டு"
            },
            {
                "sa": "मोक्ष्यसे",
                "en": "நீ சுதந்திரமாக இருப்பாய்"
            },
            {
                "sa": "अशुभात्",
                "en": "தீமையிலிருந்து"
            }
        ]
    }
}